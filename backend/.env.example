PORT=3000
NODE_ENV=development

# Optional — leave blank to skip the LLM rewrite pass and use the local
# rule-based optimizer only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional — leave blank for in-memory store.
REDIS_URL=
DATABASE_URL=

# Optional — protects POST endpoints with a Bearer token.
TOKENGUARD_API_KEY=

# CORS allowlist for the dashboard / extension.
CORS_ORIGINS=chrome-extension://*,http://localhost:5173
