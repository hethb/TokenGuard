{
  "name": "@tokenguard/shared",
  "version": "0.1.0",
  "description": "Shared types, fluff patterns, prompt optimizer, and token utilities for TokenGuard.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fluffPatterns.json": "./fluffPatterns.json",
    "./systemPromptTemplate.txt": "./systemPromptTemplate.txt"
  },
  "files": [
    "dist",
    "fluffPatterns.json",
    "systemPromptTemplate.txt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
